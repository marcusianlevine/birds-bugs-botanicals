# ── Birds, Bugs & Botanicals – Environment Variables ──────────────────────────
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# Ollama cloud (https://ollama.com — get your key at ollama.com/settings/api-keys)
OLLAMA_API_KEY=ollama_...
# Optional overrides (defaults shown):
# OLLAMA_BASE_URL=https://api.ollama.com/v1
# OLLAMA_MODEL=llama3.3

# Kling AI — get your API key from https://kling.ai/dev/api-key
# As of June 2026, Kling uses simple Bearer token auth (API key only, no secret needed).
KLING_API_KEY=...
# KLING_BASE_URL=https://api-singapore.klingai.com   # default for international users

# Instagram Graph API
# Get these from https://developers.facebook.com → your app → Instagram Basic Display
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_ACCOUNT_ID=...          # numeric IG business/creator account ID

# TikTok Content Posting API
# Get client_key + client_secret from https://developers.tiktok.com → your app
# Then run `make auth-tiktok-save` to generate TIKTOK_ACCESS_TOKEN via OAuth
# Add http://localhost:8080/callback as a redirect URI in your TikTok app first
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...
TIKTOK_ACCESS_TOKEN=...           # generated by tiktok_auth.py
TIKTOK_REFRESH_TOKEN=...          # generated by tiktok_auth.py (optional)

# eBird API (https://ebird.org/api/keygen)
EBIRD_API_KEY=...

# Optional: override default output directory
# OUTPUT_DIR=./output
