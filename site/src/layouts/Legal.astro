---
export interface Props {
  title: string;
  effectiveDate: string;
}
const { title, effectiveDate } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Birds, Bugs &amp; Botanicals</title>
  <style>
    body {
      font-family: -apple-system, "Segoe UI", Helvetica, Arial, sans-serif;
      max-width: 700px;
      margin: 40px auto;
      padding: 0 20px;
      line-height: 1.6;
      color: #222;
    }
    h1 { font-size: 1.6em; }
    h2 { font-size: 1.15em; margin-top: 1.8em; }
    p { margin: 0.8em 0; }
    a { color: #2a6f3f; }
    .effective-date { color: #666; font-size: 0.95em; }
    .back-link { display: inline-block; margin-top: 2.5em; font-size: 0.9em; }
  </style>
</head>
<body>
  <h1>{title}</h1>
  <p class="effective-date">Effective Date: {effectiveDate}</p>
  <slot />
  <p class="back-link"><a href={`${import.meta.env.BASE_URL}`}>&larr; Back to home</a></p>
</body>
</html>
